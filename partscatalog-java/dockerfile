# Use multi-stage build for efficiency
FROM eclipse-temurin:21-jre-jammy

WORKDIR /app

# Copy the fat jar and libraries
COPY target/partscatalog-java.jar /app/app.jar
COPY target/libs /app/libs

# Environment variable for DB connection (to be used later)
ENV DB_URL=jdbc:postgresql://partscatalog-db:5432/partscatalog

EXPOSE 8080

CMD ["java", "-cp", "app.jar:libs/*", "com.example.partscatalog.Main"]
