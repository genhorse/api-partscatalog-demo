package com.example.partscatalog;

import io.helidon.webserver.http.HttpRules;
import io.helidon.webserver.http.HttpService;
import io.helidon.webserver.http.ServerRequest;
import io.helidon.webserver.http.ServerResponse;
import java.util.logging.Logger;

/**
 * Service to handle catalog search requests.
 */
public class TriadService implements HttpService {

    private static final Logger LOGGER = Logger.getLogger(TriadService.class.getName());

    @Override
    public void routing(HttpRules rules) {
        rules
            .get("/", this::getDefaultMessage)
            .get("/search/{triad}", this::searchByTriad);
    }

    private void getDefaultMessage(ServerRequest request, ServerResponse response) {
        LOGGER.info("Default endpoint called.");
        response.send("Partscatalog API v1.1.0 is running. Ready for Triad Search.");
    }

    private void searchByTriad(ServerRequest request, ServerResponse response) {
        String triad = request.path().pathParameters().get("triad");
        LOGGER.info("Searching for triad: " + triad);
        
        // This is where we will implement the unique search logic 
        // that replaces the Base64 assumption.
        response.send("Results for Triad [" + triad + "]: No items found yet.");
    }
}
